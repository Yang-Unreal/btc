{
	"name": "example-basic",
	"type": "module",
	"scripts": {
		"dev": "vinxi dev",
		"build": "echo '=== BUILD DIAG ===' && echo \"Node: $(node -v)\" && echo \"Bun: $(bun -v)\" && echo \"HL_KEY: $([ -n \"$HL_PRIVATE_KEY\" ] && echo SET || echo NOT_SET)\" && echo \"HL_KEY_LEN: ${HL_PRIVATE_KEY:-0}\" && bun run scripts/patch-noble-hashes.mjs && echo '=== PATCH DONE ===' && bun run build:app",
		"build:app": "vinxi build",
		"start": "vinxi start",
		"version": "vinxi version",
		"db:push": "drizzle-kit push",
		"monitor:ma": "bun run src/monitor/ma-convergence.ts",
		"monitor:4h": "bun run src/monitor/4h-entanglement.ts",
		"monitor:td": "bun run src/monitor/td-sequential.ts"
	},
	"dependencies": {
		"@nktkas/hyperliquid": "^0.33.1",
		"@solidjs/meta": "^0.29.4",
		"@solidjs/router": "^0.15.4",
		"@solidjs/start": "^1.3.2",
		"@tanstack/solid-query": "^5.101.2",
		"drizzle-orm": "^0.45.2",
		"lightweight-charts": "^5.2.0",
		"postgres": "^3.4.9",
		"solid-js": "^1.9.14",
		"viem": "^2.55.0",
		"vinxi": "^0.5.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.7",
		"@tailwindcss/vite": "^4.3.2",
		"@types/bun": "^1.3.14",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"glob": "^11.1.0",
		"sitemap": "^8.0.3",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.0"
	},
	"engines": {
		"node": ">=22"
	}
}
